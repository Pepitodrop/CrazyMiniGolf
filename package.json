{
  "name": "crazy-mini-golf",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "description": "A nine-hole browser minigolf game with a real Brainfuck state-transition engine.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:levels": "tsx scripts/validate-levels.ts",
    "analyze:levels": "bash scripts/run-analysis.sh",
    "generate:engine": "tsx scripts/generate-brainfuck-engine.ts",
    "check:engine": "tsx scripts/generate-brainfuck-engine.ts --check",
    "test:e2e": "playwright test",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/jsdom": "21.1.7",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=20"
  }
}
